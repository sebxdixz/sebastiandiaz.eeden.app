{
  "expo": {
    "name": "Sebastian Diaz - Portfolio",
    "slug": "sebastiandiaz-portfolio",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "dist"
    },
    "plugins": [
      "react-native-reanimated/plugin"
    ]
  }
}
